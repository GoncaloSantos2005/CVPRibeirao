@using SistemaPDI.Contracts.DTOs
@model List<LocalizacaoDto>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Gestăo de Localizaçőes";
    var perfil = ViewBag.Perfil as string;
    var podeGerir = perfil == "ADMINISTRADOR" || perfil == "GESTOR";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 text-dark">Gestăo de Localizaçőes</h4>
        <p class="text-muted mb-0" style="font-size: 13px;">Gere as localizaçőes físicas do armazém (armários, prateleiras, frigoríficos).</p>
    </div>
    @if (podeGerir)
    {
        <a asp-action="Criar" class="btn btn-cvp">
            <i class="bi bi-plus-lg me-1"></i> Nova Localizaçăo
        </a>
    }
</div>

<div class="mb-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary @(ViewData["Filtro"] == null ? "active" : "")">Todas</a>
    @if (podeGerir)
    {
        <a asp-action="Desativadas" class="btn btn-sm btn-outline-secondary @(ViewData["Filtro"]?.ToString() == "desativadas" ? "active" : "")">Desativadas</a>
    }
</div>

<div class="card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Código</th>
                    <th>Label</th>
                    <th>Tipo</th>
                    <th>Zona</th>
                    <th>Prateleira</th>
                    <th>Nível</th>
                    <th class="text-center">Estado</th>
                    <th class="text-end pe-3">Açőes</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted">Nenhuma localizaçăo encontrada.</td></tr>
                }
                else
                {
                    @foreach (var loc in Model)
                    {
                        <tr class="@(!loc.Ativo ? "table-secondary" : "")">
                            <td class="ps-3">
                                <span class="badge bg-dark">@loc.Codigo</span>
                            </td>
                            <td>
                                <span class="fw-semibold text-dark">
                                    @switch (loc.Tipo)
                                    {
                                        case SistemaPDI.Domain.Enums.TipoLocalizacao.ARMARIO:
                                            <i class="bi bi-box-seam me-2 text-primary"></i>
                                            break;
                                        case SistemaPDI.Domain.Enums.TipoLocalizacao.FRIGORIFICO:
                                            <i class="bi bi-snow me-2 text-info"></i>
                                            break;
                                        case SistemaPDI.Domain.Enums.TipoLocalizacao.ZONA:
                                            <i class="bi bi-geo-alt me-2 text-warning"></i>
                                            break;
                                        default:
                                            <i class="bi bi-bookshelf me-2 text-secondary"></i>
                                            break;
                                    }
                                    @loc.Label
                                </span>
                            </td>
                            <td>
                                <span class="badge @GetTipoBadgeClass(loc.Tipo)">@loc.TipoNome</span>
                            </td>
                            <td class="text-muted small">@loc.Zona</td>
                            <td class="text-muted small">@(loc.Prateleira ?? "—")</td>
                            <td class="text-muted small">@(loc.Nivel ?? "—")</td>
                            <td class="text-center">
                                @if (loc.Ativo)
                                {
                                    <span class="badge bg-success">Ativa</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativa</span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                @if (podeGerir)
                                {
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-action="Editar" asp-route-id="@loc.Id" class="btn btn-sm btn-outline-primary py-1 px-2 border-0" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <form asp-action="AlternarEstado" asp-route-id="@loc.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-secondary py-1 px-2 border-0" title="Ativar/Desativar">
                                                <i class="bi bi-power"></i>
                                            </button>
                                        </form>

                                        @if (perfil == "ADMINISTRADOR")
                                        {
                                            <form asp-action="Remover" asp-route-id="@loc.Id" method="post" style="display:inline;"
                                                  onsubmit="return confirm('ATENÇĂO: Deseja apagar permanentemente esta localizaçăo?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2 border-0" title="Apagar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetTipoBadgeClass(SistemaPDI.Domain.Enums.TipoLocalizacao tipo)
    {
        return tipo switch
        {
            SistemaPDI.Domain.Enums.TipoLocalizacao.ARMARIO => "bg-primary",
            SistemaPDI.Domain.Enums.TipoLocalizacao.FRIGORIFICO => "bg-info",
            SistemaPDI.Domain.Enums.TipoLocalizacao.ZONA => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
}