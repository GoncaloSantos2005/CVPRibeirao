@using SistemaPDI.Domain.Enums
@model SistemaPDI.Contracts.DTOs.RegistarUtilizadorDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Novo Utilizador";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none small text-muted">
        <i class="bi bi-arrow-left"></i> Voltar aos Utilizadores
    </a>
    <h4 class="fw-bold text-dark mt-2">Criar Novo Utilizador</h4>
    <p class="text-muted" style="font-size: 13px;">Adicione um novo utilizador ao sistema.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4">

            <div asp-validation-summary="All" class="alert alert-danger mb-3"
                 style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <form asp-action="Criar" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Email <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="utilizador@cvp.pt" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Nome Completo <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="NomeCompleto" class="form-control" placeholder="Nome do utilizador" />
                    </div>
                    <span asp-validation-for="NomeCompleto" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Password <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 6 caracteres" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Perfil <span class="text-danger">*</span></label>
                    <select asp-for="Perfil" class="form-select"
                            asp-items="Html.GetEnumSelectList<Perfil>()">
                        <option value="">-- Selecionar Perfil --</option>
                    </select>
                    <span asp-validation-for="Perfil" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                    <button type="submit" class="btn btn-cvp px-4">
                        <i class="bi bi-person-plus me-1"></i> Criar Utilizador
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <h6 class="fw-bold text-uppercase small text-muted mb-3">
                    <i class="bi bi-info-circle me-2"></i>Sobre os Perfis
                </h6>

                <div class="mb-3 pb-3 border-bottom">
                    <span class="badge badge-socorrista mb-1">SOCORRISTA</span>
                    <p class="small text-muted mb-0">Acesso apenas para consulta de artigos e alertas.</p>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <span class="badge badge-gestor mb-1">GESTOR</span>
                    <p class="small text-muted mb-0">Pode gerir artigos, categorias, entradas e saídas de stock.</p>
                </div>

                <div>
                    <span class="badge badge-admin mb-1">ADMINISTRADOR</span>
                    <p class="small text-muted mb-0">Acesso total: utilizadores, fornecedores e todas as operações.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}