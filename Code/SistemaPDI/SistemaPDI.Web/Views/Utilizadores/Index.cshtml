@using SistemaPDI.Domain.Enums
@model List<SistemaPDI.Contracts.DTOs.UtilizadorDto>

@{
    ViewData["Title"] = "Gestão de Utilizadores";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 text-dark">Gestão de Utilizadores</h4>
        <p class="text-muted mb-0" style="font-size: 13px;">Gira os utilizadores e permissões do sistema.</p>
    </div>
    <a asp-action="Criar" class="btn btn-cvp">
        <i class="bi bi-plus-lg me-1"></i> Novo Utilizador
    </a>
</div>

<div class="mb-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary @(ViewData["Filtro"] == null ? "active" : "")">Todos</a>
    <a asp-action="Index" asp-route-filtro="ativos" class="btn btn-sm btn-outline-success @(ViewData["Filtro"]?.ToString() == "ativos" ? "active" : "")">Ativos</a>
    <a asp-action="Index" asp-route-filtro="inativos" class="btn btn-sm btn-outline-danger @(ViewData["Filtro"]?.ToString() == "inativos" ? "active" : "")">Inativos</a>
</div>

<div class="card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Utilizador</th>
                    <th>Email</th>
                    <th class="text-center">Perfil</th>
                    <th class="text-center">Estado</th>
                    <th>Último Acesso</th>  <!-- ← Alterado de "Criado Em" -->
                    <th class="text-end pe-3">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-people" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">Nenhum utilizador encontrado.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var u in Model)
                    {
                        <tr class="@(!u.Ativo ? "table-secondary" : "")">
                            <td class="ps-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                                         style="width: 36px; height: 36px; background: @(u.Perfil == "ADMINISTRADOR" ? "#C8102E" : u.Perfil == "GESTOR" ? "#E65100" : "#2E7D32"); color: white; font-weight: 600; font-size: 14px;">
                                        @u.NomeCompleto.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-semibold text-dark">@u.NomeCompleto</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted small">
                                    <i class="bi bi-envelope me-1"></i>@u.Email
                                </span>
                            </td>
                            <td class="text-center">
                                @{
                                    var badgeClass = u.Perfil switch
                                    {
                                        "ADMINISTRADOR" => "badge-admin",
                                        "GESTOR" => "badge-gestor",
                                        _ => "badge-socorrista"
                                    };
                                    var icon = u.Perfil switch
                                    {
                                        "ADMINISTRADOR" => "bi-shield-lock",
                                        "GESTOR" => "bi-person-gear",
                                        _ => "bi-person"
                                    };
                                }
                                <span class="badge @badgeClass">
                                    <i class="bi @icon me-1"></i>@u.Perfil
                                </span>
                            </td>
                            <td class="text-center">
                                @if (u.Ativo)
                                {
                                    <span class="badge badge-ativo">
                                        <i class="bi bi-check-circle me-1"></i>Ativo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-inativo">
                                        <i class="bi bi-x-circle me-1"></i>Inativo
                                    </span>
                                }
                            </td>
                            <td>
                                @if (u.UltimoLogin.HasValue)
                                {
                                    var diff = DateTime.UtcNow - u.UltimoLogin.Value;
                                    string texto;
                                    string corIcone;
                                    
                                    if (diff.TotalMinutes < 5)
                                    {
                                        texto = "Agora";
                                        corIcone = "text-success";
                                    }
                                    else if (diff.TotalHours < 1)
                                    {
                                        texto = $"Há {(int)diff.TotalMinutes} min";
                                        corIcone = "text-success";
                                    }
                                    else if (diff.TotalHours < 24)
                                    {
                                        texto = $"Há {(int)diff.TotalHours}h";
                                        corIcone = "text-warning";
                                    }
                                    else if (diff.TotalDays < 7)
                                    {
                                        texto = $"Há {(int)diff.TotalDays} dias";
                                        corIcone = "text-warning";
                                    }
                                    else
                                    {
                                        texto = u.UltimoLogin.Value.ToString("dd/MM/yyyy");
                                        corIcone = "text-muted";
                                    }
                                    
                                    <span class="small" title="@u.UltimoLogin.Value.ToString("dd/MM/yyyy HH:mm")">
                                        <i class="bi bi-circle-fill @corIcone" style="font-size: 6px; vertical-align: middle;"></i>
                                        @texto
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">
                                        <i class="bi bi-dash"></i> Nunca
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="Editar" asp-route-id="@u.Id" 
                                       class="btn btn-sm btn-outline-primary py-1 px-2 border-0" 
                                       title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <!-- Reset Password - Apenas Admin -->
                                    <button type="button" 
                                            class="btn btn-sm btn-outline-warning py-1 px-2 border-0" 
                                            title="Redefinir Password"
                                            data-bs-toggle="modal" 
                                            data-bs-target="#modalResetPassword"
                                            data-user-id="@u.Id"
                                            data-user-nome="@u.NomeCompleto">
                                        <i class="bi bi-key"></i>
                                    </button>

                                    <!-- Ativar/Desativar -->
                                    @if (u.Ativo)
                                    {
                                        <form asp-action="Desativar" asp-route-id="@u.Id" method="post" style="display:inline;"
                                              onsubmit="return confirm('Desativar o utilizador @u.NomeCompleto?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2 border-0" title="Desativar">
                                                <i class="bi bi-person-slash"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Ativar" asp-route-id="@u.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success py-1 px-2 border-0" title="Ativar">
                                                <i class="bi bi-person-check"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Reset Password -->
<div class="modal fade" id="modalResetPassword" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title">
                    <i class="bi bi-key text-warning me-2"></i>Redefinir Password
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="userId" id="resetUserId" />
                    <p class="text-muted">A redefinir password para: <strong id="resetUserNome"></strong></p>
                    
                    <div class="mb-3">
                        <label class="form-label">Nova Password</label>
                        <input type="password" name="novaPassword" class="form-control" required minlength="6" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirmar Password</label>
                        <input type="password" name="confirmarPassword" class="form-control" required minlength="6" />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-cvp">Redefinir</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalResetPassword').addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            document.getElementById('resetUserId').value = button.getAttribute('data-user-id');
            document.getElementById('resetUserNome').textContent = button.getAttribute('data-user-nome');
        });
    </script>
}