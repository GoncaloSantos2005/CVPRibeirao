@using SistemaPDI.Contracts.DTOs
@model AtualizarLoteDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Editar Lote";
    var lote = ViewBag.Lote as LoteDto;
    var isAdmin = (bool)(ViewBag.IsAdmin ?? false);
    var localizacoes = (ViewBag.Localizacoes as List<LocalizacaoDropdownDto>) ?? new List<LocalizacaoDropdownDto>();
}

<link rel="stylesheet" href="~/css/lotes-index.css" />

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none small text-muted">
        <i class="bi bi-arrow-left"></i> Voltar aos Lotes
    </a>
    <h4 class="fw-bold text-dark mt-3">Editar Lote: <span class="text-primary">@lote?.NumeroLote</span></h4>
    <p class="text-muted" style="font-size: 13px;">
        @lote?.NomeArtigo (<strong>@lote?.SKU</strong>)
    </p>
</div>

@if (!isAdmin)
{
    <div class="alert alert-info alert-status mb-4">
        <i class="bi bi-info-circle me-2"></i>
        <strong>Aviso:</strong> Como GESTOR, vocę pode editar a data de validade, preço e localizaçăo. 
        O stock só pode ser modificado pelo Administrador para garantir a integridade dos registos.
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card detail-card p-4">
            <form asp-action="Editar" asp-route-id="@lote?.Id" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="alert alert-danger mb-3"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <!-- Campos năo editáveis (apenas visualizaçăo) -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Número do Lote</label>
                        <input type="text" class="form-control" value="@lote?.NumeroLote" disabled />
                        <small class="text-muted">Năo editável</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Artigo</label>
                        <input type="text" class="form-control" value="@lote?.NomeArtigo" disabled />
                        <small class="text-muted">Năo editável</small>
                    </div>
                </div>

                <hr class="my-4" />

                <!-- Campos editáveis -->
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Data de Validade <span class="text-danger">*</span></label>
                        <input asp-for="DataValidade" type="date" class="form-control" />
                        <span asp-validation-for="DataValidade" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Preço Unitário (€)</label>
                        <input asp-for="PrecoUnitario" type="number" step="0.01" class="form-control" min="0" />
                        <span asp-validation-for="PrecoUnitario" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Localizaçăo</label>
                        <select name="LocalizacaoId" class="form-select">
                            <option value="">-- Selecione uma localizaçăo --</option>
                            @foreach (var loc in localizacoes)
                            {
                                <option value="@loc.Id" selected="@(lote?.LocalizacaoId == loc.Id)">@loc.Label</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">
                            Quantidade Disponível
                            @if (!isAdmin)
                            {
                                <span class="badge bg-secondary ms-2">Apenas Admin</span>
                            }
                        </label>
                        <input asp-for="QtdDisponivel" type="number" class="form-control" min="0" disabled="@(!isAdmin)" />
                        @if (!isAdmin)
                        {
                            <input type="hidden" asp-for="QtdDisponivel" />
                        }
                        <span asp-validation-for="QtdDisponivel" class="text-danger small"></span>
                        @if (lote?.QtdReservada > 0)
                        {
                            <small class="text-warning d-block mt-2">
                                <i class="bi bi-exclamation-triangle"></i> 
                                Mínimo: @lote.QtdReservada (quantidade reservada)
                            </small>
                        }
                        @if (!isAdmin)
                        {
                            <small class="text-muted d-block mt-2">
                                <i class="bi bi-lock"></i> Este campo está protegido. Apenas o Administrador pode modificar o stock.
                            </small>
                        }
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                    <button type="submit" class="btn btn-cvp px-4">
                        <i class="bi bi-save me-1"></i> Guardar Alteraçőes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Informaçőes -->
        <div class="card detail-card mb-4 bg-light">
            <div class="detail-card-header bg-white">
                <h6><i class="bi bi-info-circle me-2"></i>Informaçőes</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                    <span class="small">Quantidade Reservada:</span>
                    <span class="badge badge-warning">@lote?.QtdReservada</span>
                </div>

                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                    <span class="small">Realmente Disponível:</span>
                    <span class="badge badge-active">@lote?.QtdRealmenteDisponivel</span>
                </div>

                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                    <span class="small">Estado:</span>
                    @if (lote?.Ativo == true)
                    {
                        <span class="badge badge-active">Ativo</span>
                    }
                    else
                    {
                        <span class="badge badge-inactive">Inativo</span>
                    }
                </div>

                <div class="d-flex justify-content-between">
                    <span class="small">Criado em:</span>
                    <span class="small">@lote?.CriadoEm.ToString("dd/MM/yyyy")</span>
                </div>
            </div>
        </div>

        <!-- Status Badges -->
        @if (lote?.EstaExpirado == true)
        {
            <div class="alert alert-danger alert-status">
                <i class="bi bi-x-octagon me-2"></i>
                <strong>EXPIRADO</strong>
            </div>
        }
        else if (lote?.ValidadeProxima == true)
        {
            <div class="alert alert-warning alert-status">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Validade Próxima</strong>
            </div>
        }
        else
        {
            <div class="alert alert-success alert-status">
                <i class="bi bi-check-circle me-2"></i>
                <strong>Válido</strong>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}