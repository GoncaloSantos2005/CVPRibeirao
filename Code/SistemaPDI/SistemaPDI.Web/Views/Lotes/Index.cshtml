@using SistemaPDI.Contracts.DTOs
@model List<LoteDto>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Gestăo de Lotes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 text-dark">Gestăo de Lotes</h4>
        <p class="text-muted mb-0" style="font-size: 13px;">Controlo de lotes, validades e rastreabilidade FEFO.</p>
    </div>
    <a asp-action="Criar" class="btn btn-cvp">
        <i class="bi bi-plus-lg me-1"></i> Novo Lote
    </a>
</div>

<div class="mb-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary active">Todos</a>
    <a asp-action="AlertasValidade" class="btn btn-sm btn-outline-warning">
        <i class="bi bi-exclamation-triangle me-1"></i> Alertas Validade
    </a>
</div>

<div class="card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Artigo</th>
                    <th>Nş Lote</th>
                    <th class="text-center">Validade</th>
                    <th class="text-center">Disponível</th>
                    <th class="text-center">Reservado</th>
                    <th>Localizaçăo</th>
                    <th class="text-center">Estado</th>
                    <th class="text-end pe-3">Açőes</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="bi bi-box-seam" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">Nenhum lote encontrado.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var lote in Model)
                    {
                        var rowClass = !lote.Ativo ? "table-secondary" : 
                                       lote.EstaExpirado ? "table-danger" : 
                                       lote.ValidadeProxima ? "table-warning" : "";
                        
                        <tr class="@rowClass">
                            <td class="ps-3">
                                <div>
                                    <span class="fw-semibold text-dark">@lote.NomeArtigo</span>
                                    <br />
                                    <small class="text-muted">@lote.SKU</small>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-bold">@lote.NumeroLote</span>
                            </td>
                            <td class="text-center">
                                @if (lote.EstaExpirado)
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-circle me-1"></i>EXPIRADO
                                    </span>
                                    <br />
                                    <small class="text-muted">@lote.DataValidade.ToString("dd/MM/yyyy")</small>
                                }
                                else if (lote.ValidadeProxima)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-exclamation-triangle me-1"></i>ATENÇĂO
                                    </span>
                                    <br />
                                    <small class="text-muted">@lote.DataValidade.ToString("dd/MM/yyyy")</small>
                                }
                                else
                                {
                                    <span class="text-success">
                                        <i class="bi bi-check-circle me-1"></i>
                                    </span>
                                    <span>@lote.DataValidade.ToString("dd/MM/yyyy")</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="fw-bold fs-6">@lote.QtdRealmenteDisponivel</span>
                                <small class="text-muted">/ @lote.QtdDisponivel</small>
                            </td>
                            <td class="text-center">
                                @if (lote.QtdReservada > 0)
                                {
                                    <span class="badge bg-info">@lote.QtdReservada</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @if (!string.IsNullOrEmpty(lote.LocalizacaoLabel))
                                {
                                    <i class="bi bi-geo-alt me-1"></i>@lote.LocalizacaoLabel
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (lote.Ativo)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inativo</span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="Detalhes" asp-route-id="@lote.Id" 
                                       class="btn btn-sm btn-outline-info py-1 px-2 border-0" title="Ver Detalhes">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Editar" asp-route-id="@lote.Id" 
                                       class="btn btn-sm btn-outline-primary py-1 px-2 border-0" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    @if (lote.Ativo && lote.QtdReservada == 0)
                                    {
                                        <form asp-action="Desativar" asp-route-id="@lote.Id" method="post" style="display:inline;"
                                              onsubmit="return confirm('Desativar este lote?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2 border-0" title="Desativar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>