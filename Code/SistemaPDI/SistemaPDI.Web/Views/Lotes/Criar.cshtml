@using SistemaPDI.Contracts.DTOs
@model CriarLoteDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Novo Lote";
    var artigos = ViewBag.Artigos as List<ArtigoDto> ?? new List<ArtigoDto>();
    var artigoSelecionado = ViewBag.ArtigoIdSelecionado as int?;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none small text-muted">
        <i class="bi bi-arrow-left"></i> Voltar aos Lotes
    </a>
    <h4 class="fw-bold text-dark mt-2">Registar Novo Lote</h4>
    <p class="text-muted" style="font-size: 13px;">Registe um novo lote durante a receçăo de stock.</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4">
            <form asp-action="Criar" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="alert alert-danger mb-3"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="row g-3">
                    <!-- Artigo -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Artigo <span class="text-danger">*</span></label>
                        <select asp-for="ArtigoId" class="form-select">
                            <option value="0">-- Selecionar Artigo --</option>
                            @foreach (var artigo in artigos.Where(a => a.Ativo))
                            {
                                <option value="@artigo.Id" selected="@(artigo.Id == artigoSelecionado)">
                                    @artigo.SKU - @artigo.Nome
                                </option>
                            }
                        </select>
                        <span asp-validation-for="ArtigoId" class="text-danger small"></span>
                    </div>

                    <!-- Número do Lote -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Número do Lote <span class="text-danger">*</span></label>
                        <input asp-for="NumeroLote" class="form-control" placeholder="Ex: LOT-2024-001" />
                        <span asp-validation-for="NumeroLote" class="text-danger small"></span>
                        <small class="text-muted">Código impresso na embalagem</small>
                    </div>

                    <!-- Data de Validade -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Data de Validade <span class="text-danger">*</span></label>
                        <input asp-for="DataValidade" type="date" class="form-control" />
                        <span asp-validation-for="DataValidade" class="text-danger small"></span>
                    </div>

                    <hr class="my-3" />

                    <!-- Quantidade -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Quantidade <span class="text-danger">*</span></label>
                        <input asp-for="Quantidade" type="number" class="form-control" min="1" placeholder="0" />
                        <span asp-validation-for="Quantidade" class="text-danger small"></span>
                    </div>

                    <!-- Preço Unitário -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Preço Unitário (€)</label>
                        <input asp-for="PrecoUnitario" type="number" step="0.01" class="form-control" min="0" placeholder="0.00" />
                        <span asp-validation-for="PrecoUnitario" class="text-danger small"></span>
                    </div>

                    <!-- Localizaçăo Física -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Localizaçăo</label>
                        <select asp-for="LocalizacaoId" asp-items="@(ViewBag.Localizacoes as List<SelectListItem>)" class="form-select">
                            <option value="">-- Selecione uma localizaçăo --</option>
                        </select>
                        <span asp-validation-for="LocalizacaoId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                    <button type="submit" class="btn btn-cvp px-4">
                        <i class="bi bi-box-seam me-1"></i> Registar Lote
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <h6 class="fw-bold text-uppercase small text-muted mb-3">
                    <i class="bi bi-info-circle me-2"></i>Sobre Lotes
                </h6>
                
                <div class="mb-3 pb-3 border-bottom">
                    <span class="badge bg-danger mb-1">RN06</span>
                    <p class="small text-muted mb-0">Năo é permitido registar lotes com o mesmo número para o mesmo artigo.</p>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <span class="badge bg-warning text-dark mb-1">RN17</span>
                    <p class="small text-muted mb-0">A data de validade năo pode ser inferior ŕ data atual.</p>
                </div>

                <div>
                    <span class="badge bg-info mb-1">FEFO</span>
                    <p class="small text-muted mb-0">First Expired, First Out - Os lotes com validade mais próxima săo consumidos primeiro.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}