@using SistemaPDI.Contracts.DTOs
@model LoteDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = $"Lote {Model.NumeroLote}";
}

<link rel="stylesheet" href="~/css/lotes-index.css" />

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none small text-muted">
        <i class="bi bi-arrow-left"></i> Voltar aos Lotes
    </a>
    <div class="d-flex justify-content-between align-items-start mt-3">
        <div>
            <h4 class="fw-bold text-dark mb-1">
                Lote: <span class="text-primary">@Model.NumeroLote</span>
            </h4>
            <p class="text-muted mb-0" style="font-size: 13px;">
                @Model.NomeArtigo (<strong>@Model.SKU</strong>)
            </p>
        </div>
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i> Editar
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Coluna Esquerda -->
    <div class="col-md-6">
        <!-- Estado do Lote -->
        <div class="card detail-card mb-4">
            <div class="detail-card-header">
                <h6><i class="bi bi-heart-pulse me-2"></i>Estado do Lote</h6>
            </div>
            <div class="card-body">
                @if (Model.EstaExpirado)
                {
                    <div class="alert alert-danger alert-status mb-3">
                        <i class="bi bi-x-octagon me-2"></i>
                        <strong>EXPIRADO</strong> - Este lote já ultrapassou a data de validade.
                    </div>
                }
                else if (Model.ValidadeProxima)
                {
                    <div class="alert alert-warning alert-status mb-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>ATENÇÃO</strong> - Validade próxima (menos de 15 dias).
                    </div>
                }
                else
                {
                    <div class="alert alert-success alert-status mb-3">
                        <i class="bi bi-check-circle me-2"></i>
                        <strong>OK</strong> - Lote dentro do prazo de validade.
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted small">Estado</span>
                    @if (Model.Ativo)
                    {
                        <span class="badge badge-active">Ativo</span>
                    }
                    else
                    {
                        <span class="badge badge-inactive">Inativo</span>
                    }
                </div>

                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted small">Data de Validade</span>
                    <span class="fw-semibold">
                        @(Model.DataValidade?.ToString("dd/MM/yyyy") ?? "-")
                    </span>
                </div>

                <div class="d-flex justify-content-between align-items-center py-2">
                    <span class="text-muted small">Registado em</span>
                    <span class="small">@Model.CriadoEm.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </div>

        <!-- Localização -->
        <div class="card detail-card">
            <div class="detail-card-header">
                <h6><i class="bi bi-geo-alt me-2"></i>Localização</h6>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.LocalizacaoLabel))
                {
                    <span class="fw-semibold">@Model.LocalizacaoLabel</span>
                }
                else
                {
                    <span class="text-muted">Não definida</span>
                }
            </div>
        </div>
    </div>

    <!-- Coluna Direita -->
    <div class="col-md-6">
        <!-- Stock -->
        <div class="card detail-card mb-4">
            <div class="detail-card-header">
                <h6><i class="bi bi-box-seam me-2"></i>Stock</h6>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-4">
                    <div class="col-4">
                        <div class="stock-box">
                            <h3 class="text-primary">@Model.QtdDisponivel</h3>
                            <small>Total</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stock-box">
                            <h3 class="text-warning">@Model.QtdReservada</h3>
                            <small>Reservado</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stock-box">
                            <h3 class="text-success">@Model.QtdRealmenteDisponivel</h3>
                            <small>Disponível</small>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center py-2">
                    <span class="text-muted small">Preço Unitário</span>
                    <span class="fw-semibold">@(Model.PrecoUnitario?.ToString("C2") ?? "-")</span>
                </div>
            </div>
        </div>

        <!-- Ações Rápidas -->
        @if (Model.Ativo && Model.QtdReservada == 0)
        {
            <div class="card detail-card bg-light">
                <div class="detail-card-header bg-white">
                    <h6><i class="bi bi-lightning me-2"></i>Ações Rápidas</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Desativar" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Deseja desativar este lote?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash me-1"></i> Desativar Lote
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>