@using SistemaPDI.Contracts.DTOs
@model List<AlertaValidadeDto>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Alertas de Validade";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 text-dark">
            <i class="bi bi-exclamation-triangle text-warning me-2"></i>Alertas de Validade
        </h4>
        <p class="text-muted mb-0" style="font-size: 13px;">Lotes com validade próxima (15 dias) ou já expirados (RN13).</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
            <h5 class="mt-3">Tudo em ordem!</h5>
            <p class="text-muted">Năo existem lotes com validade próxima ou expirados.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var alerta in Model.OrderBy(a => a.DataValidade))
        {
            var cardClass = alerta.JaExpirado ? "border-danger" : "border-warning";
            var headerClass = alerta.JaExpirado ? "bg-danger text-white" : "bg-warning text-dark";
            var icon = alerta.JaExpirado ? "bi-x-octagon" : "bi-exclamation-triangle";
            var statusText = alerta.JaExpirado ? "EXPIRADO" : $"Expira em {alerta.DiasParaExpirar} dias";

            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm @cardClass">
                    <div class="card-header @headerClass d-flex justify-content-between align-items-center">
                        <span><i class="bi @icon me-2"></i>@statusText</span>
                        <span class="badge bg-light text-dark">@alerta.NumeroLote</span>
                    </div>
                    <div class="card-body">
                        <h6 class="fw-bold">@alerta.NomeArtigo</h6>
                        
                        <div class="d-flex justify-content-between small text-muted mb-2">
                            <span><i class="bi bi-calendar me-1"></i>Validade:</span>
                            <span class="fw-semibold">@alerta.DataValidade.ToString("dd/MM/yyyy")</span>
                        </div>
                        
                        <div class="d-flex justify-content-between small text-muted mb-2">
                            <span><i class="bi bi-box me-1"></i>Quantidade:</span>
                            <span class="fw-semibold">@alerta.QtdDisponivel unidades</span>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(alerta.LocalizacaoLabel))
                        {
                            <div class="d-flex justify-content-between small text-muted">
                                <span><i class="bi bi-geo-alt me-1"></i>@alerta.LocalizacaoLabel</span>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Detalhes" asp-route-id="@alerta.LoteId" class="btn btn-sm btn-outline-primary w-100">
                            <i class="bi bi-eye me-1"></i> Ver Detalhes
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}