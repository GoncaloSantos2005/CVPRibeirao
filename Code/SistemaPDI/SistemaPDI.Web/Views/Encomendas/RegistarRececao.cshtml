@using SistemaPDI.Web.Models
@model RegistarRececaoViewModel
@{
    ViewData["Title"] = "Registar Receção";
    var encomenda = ViewBag.Encomenda as EncomendaDto;
    var localizacoes = ViewBag.Localizacoes as List<LocalizacaoDropdownDto> ?? new List<LocalizacaoDropdownDto>();
}

@* ══════════════════════════════════════════════════════════════════════ *@
@* HEADER *@
@* ══════════════════════════════════════════════════════════════════════ *@

<div class="mb-4">
    <a asp-action="Detalhes" asp-route-id="@encomenda.Id" class="text-decoration-none small text-muted">
        <i class="bi bi-arrow-left"></i> Voltar aos Detalhes
    </a>

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mt-2">
        <div>
            <h4 class="mb-1 text-dark">
                <i class="bi bi-box-arrow-in-down text-success me-2"></i>
                Registar Receção
            </h4>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <span class="badge bg-success">
                    <i class="bi bi-box-arrow-in-down me-1"></i>RECEÇÃO
                </span>
                <span class="text-muted small">
                    Encomenda <strong>@encomenda.NumeroEncomenda</strong> — @encomenda.FornecedorNome
                </span>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Detalhes" asp-route-id="@encomenda.Id" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle me-1"></i>Cancelar
            </a>
            <button type="submit" form="formRecepcao" class="btn btn-success" id="btnRegistar" disabled>
                <i class="bi bi-check-circle me-1"></i>Registar Receção e Atualizar Stocks
            </button>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════ *@
@* CARDS DE RESUMO (estilo Detalhes) *@
@* ══════════════════════════════════════════════════════════════════════ *@

<div class="row g-3 mb-4">

    @* CARD ENCOMENDA *@
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-circle bg-primary bg-opacity-10 me-2">
                        <i class="bi bi-info-circle text-primary"></i>
                    </div>
                    <h6 class="mb-0 fw-semibold">Encomenda</h6>
                </div>
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Número:</dt>
                    <dd class="col-7 fw-semibold">@encomenda.NumeroEncomenda</dd>

                    <dt class="col-5 text-muted">Fornecedor:</dt>
                    <dd class="col-7 fw-semibold">@encomenda.FornecedorNome</dd>

                    @if (encomenda.DataEnvioFornecedor.HasValue)
                    {
                        <dt class="col-5 text-muted">Enviada em:</dt>
                        <dd class="col-7">@encomenda.DataEnvioFornecedor.Value.ToString("dd/MM/yyyy")</dd>
                    }

                    @if (encomenda.DataEntregaPrevista.HasValue)
                    {
                        var diasAtraso = (DateTime.Today - encomenda.DataEntregaPrevista.Value).Days;
                        <dt class="col-5 text-muted">Entrega Prev.:</dt>
                        <dd class="col-7">
                            <span class="@(diasAtraso > 0 ? "text-danger fw-bold" : "")">
                                @encomenda.DataEntregaPrevista.Value.ToString("dd/MM/yyyy")
                            </span>
                            @if (diasAtraso > 0)
                            {
                                <br /><span class="badge bg-danger">@diasAtraso dia(s) atraso</span>
                            }
                        </dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    @* CARD ARTIGOS *@
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-circle bg-info bg-opacity-10 me-2">
                        <i class="bi bi-box-seam text-info"></i>
                    </div>
                    <h6 class="mb-0 fw-semibold">Artigos</h6>
                </div>
                <div class="row text-center">
                    <div class="col-4">
                        <span class="text-muted small d-block">Linhas</span>
                        <strong class="fs-4">@encomenda.Linhas.Count</strong>
                    </div>
                    <div class="col-4">
                        <span class="text-muted small d-block">Aprovado</span>
                        <strong class="fs-4 text-primary">@encomenda.TotalArtigosAprovados</strong>
                    </div>
                    <div class="col-4">
                        <span class="text-muted small d-block">Pendente</span>
                        <strong class="fs-4 text-warning">@(encomenda.TotalArtigosAprovados - encomenda.TotalArtigosRecebidos)</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* CARD FINANCEIRO *@
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 border-start border-success border-3">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-circle bg-success bg-opacity-10 me-2">
                        <i class="bi bi-currency-euro text-success"></i>
                    </div>
                    <h6 class="mb-0 fw-semibold">Financeiro</h6>
                </div>
                <div class="text-center">
                    <span class="text-muted small d-block">Valor Total</span>
                    <strong class="fs-3 text-success">@encomenda.ValorTotal.ToString("C2")</strong>
                </div>
            </div>
        </div>
    </div>

    @* CARD PROGRESSO *@
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-circle bg-warning bg-opacity-10 me-2">
                        <i class="bi bi-graph-up text-warning"></i>
                    </div>
                    <h6 class="mb-0 fw-semibold">Progresso</h6>
                </div>
                <div class="text-center mb-2">
                    <strong class="fs-3 text-primary">@encomenda.PercentualRecebido.ToString("F0")%</strong>
                </div>
                <div class="progress mb-2" style="height: 10px;">
                    <div class="progress-bar bg-info"
                         role="progressbar"
                         style="width: @encomenda.PercentualRecebido%"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                    <span>Recebido: <strong class="text-success">@encomenda.TotalArtigosRecebidos</strong></span>
                    <span id="badgeConferidos">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-check2-square me-1"></i>
                            <span id="artigosConferidos">0</span>/@encomenda.Linhas.Count conf.
                        </span>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════ *@
@* TUTORIAL *@
@* ══════════════════════════════════════════════════════════════════════ *@

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 py-3">
        <h6 class="mb-0 fw-bold">
            <i class="bi bi-lightbulb me-2 text-warning"></i>Como Proceder
        </h6>
    </div>
    <div class="card-body pt-0">
        <div class="row g-0">
            <div class="col-md-3 d-flex align-items-start pe-md-4 mb-3 mb-md-0">
                <div class="icon-circle-sm bg-primary me-3 flex-shrink-0"><span class="text-white fw-bold" style="font-size:11px;">1</span></div>
                <div><strong class="small d-block">Conferir artigos</strong><small class="text-muted">Verifique quantidade, lote e validade de cada item</small></div>
            </div>
            <div class="col-md-3 d-flex align-items-start px-md-4 mb-3 mb-md-0" style="border-left: 1px solid #dee2e6;">
                <div class="icon-circle-sm bg-info me-3 flex-shrink-0"><span class="text-white fw-bold" style="font-size:11px;">2</span></div>
                <div><strong class="small d-block">Registar dados</strong><small class="text-muted">Preencha os campos obrigatórios para cada artigo</small></div>
            </div>
            <div class="col-md-3 d-flex align-items-start px-md-4 mb-3 mb-md-0" style="border-left: 1px solid #dee2e6;">
                <div class="icon-circle-sm bg-warning me-3 flex-shrink-0"><span class="text-white fw-bold" style="font-size:11px;">3</span></div>
                <div><strong class="small d-block">Definir localização</strong><small class="text-muted">Escolha onde cada artigo será armazenado</small></div>
            </div>
            <div class="col-md-3 d-flex align-items-start ps-md-4" style="border-left: 1px solid #dee2e6;">
                <div class="icon-circle-sm bg-success me-3 flex-shrink-0"><span class="text-white fw-bold" style="font-size:11px;">4</span></div>
                <div><strong class="small d-block">Finalizar receção</strong><small class="text-muted">Confirme e registe para atualizar os stocks</small></div>
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════ *@
@* FORMULÁRIO *@
@* ══════════════════════════════════════════════════════════════════════ *@

<form asp-action="RegistarRececao" method="post" id="formRecepcao">
    <input type="hidden" name="EncomendaId" value="@encomenda.Id" />

    @* ── CONFERÊNCIA DE ARTIGOS ── *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-check2-square me-2"></i>Conferência de Artigos
                </h6>
                <span class="badge bg-secondary">@encomenda.Linhas.Count artigo(s)</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="accordion accordion-flush" id="accordionArtigos">
                @for (int i = 0; i < encomenda.Linhas.Count; i++)
                {
                    var linha = encomenda.Linhas[i];
                    var qtdPendente = linha.QuantidadeAprovada - linha.QuantidadeRecebida;
                    var jaRecebido = linha.QuantidadeRecebida > 0;
                    var completamenteRecebido = linha.QuantidadeRecebida >= linha.QuantidadeAprovada;

                    var corBadge = completamenteRecebido ? "success" : jaRecebido ? "warning" : "secondary";
                    var iconBadge = completamenteRecebido ? "check-circle-fill" : jaRecebido ? "hourglass-split" : "circle";

                    <div class="artigo-item border-bottom" data-index="@i" data-pendente="@qtdPendente">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(i == 0 ? "" : "collapsed") bg-white"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#artigo@(i)"
                                    aria-expanded="@(i == 0 ? "true" : "false")">
                                <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="icon-circle-sm bg-@corBadge bg-opacity-10 artigo-icon">
                                            <i class="bi bi-@iconBadge text-@corBadge" style="font-size: 12px;"></i>
                                        </div>
                                        <div>
                                            <strong class="small">@linha.ArtigoNome</strong>
                                            <br /><small class="text-muted">@linha.ArtigoSKU</small>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-1 text-end">
                                        <span class="badge bg-primary">Aprov: @linha.QuantidadeAprovada</span>
                                        @if (jaRecebido)
                                        {
                                            <span class="badge bg-success">Receb: @linha.QuantidadeRecebida</span>
                                        }
                                        @if (qtdPendente > 0)
                                        {
                                            <span class="badge bg-warning text-dark">Pend: @qtdPendente</span>
                                        }
                                        else if (completamenteRecebido)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-lg"></i> Completo</span>
                                        }
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div id="artigo@(i)"
                             class="accordion-collapse collapse @(i == 0 ? "show" : "")">
                            <div class="accordion-body bg-light">
                                <input type="hidden" name="Linhas[@i].LinhaId" value="@linha.Id" />

                                @* INFO DO ARTIGO *@
                                @if (linha.PrecoUnitario.HasValue || !string.IsNullOrEmpty(linha.NumeroLote) || linha.DataValidade.HasValue)
                                {
                                    <div class="row g-3 mb-3">
                                        @if (linha.PrecoUnitario.HasValue)
                                        {
                                            <div class="col-auto">
                                                <div class="card border-0 shadow-sm px-3 py-2 text-center" style="min-width:100px;">
                                                    <small class="text-muted">Preço Unit.</small>
                                                    <strong class="text-success">@linha.PrecoUnitario.Value.ToString("C2")</strong>
                                                </div>
                                            </div>
                                        }
                                        @if (linha.Subtotal.HasValue)
                                        {
                                            <div class="col-auto">
                                                <div class="card border-0 shadow-sm px-3 py-2 text-center" style="min-width:100px;">
                                                    <small class="text-muted">Subtotal</small>
                                                    <strong class="text-success">@linha.Subtotal.Value.ToString("C2")</strong>
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(linha.NumeroLote))
                                        {
                                            <div class="col-auto">
                                                <div class="card border-0 shadow-sm px-3 py-2 text-center" style="min-width:100px;">
                                                    <small class="text-muted">Lote Previsto</small>
                                                    <span class="badge bg-info fs-6">@linha.NumeroLote</span>
                                                </div>
                                            </div>
                                        }
                                        @if (linha.DataValidade.HasValue)
                                        {
                                            <div class="col-auto">
                                                <div class="card border-0 shadow-sm px-3 py-2 text-center" style="min-width:100px;">
                                                    <small class="text-muted">Validade Prev.</small>
                                                    <strong>@linha.DataValidade.Value.ToString("dd/MM/yyyy")</strong>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                @* CAMPOS DE RECEÇÃO *@
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label class="form-label small fw-semibold text-muted">
                                            <i class="bi bi-hash me-1"></i>Quantidade Recebida *
                                        </label>
                                        <input type="number"
                                               name="Linhas[@i].QuantidadeRecebida"
                                               class="form-control form-control-lg text-center fw-bold input-qtd-recebida"
                                               min="0"
                                               max="@qtdPendente"
                                               value="@qtdPendente"
                                               required
                                               data-max="@qtdPendente"
                                               data-artigo="@linha.ArtigoNome" />
                                        <small class="text-muted">Máx: <strong>@qtdPendente</strong> un.</small>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label small fw-semibold text-muted">
                                            <i class="bi bi-upc me-1"></i>Número de Lote *
                                        </label>
                                        <input type="text"
                                               name="Linhas[@i].NumeroLote"
                                               class="form-control form-control-lg input-lote"
                                               placeholder="Ex: L-2026-001"
                                               maxlength="100"
                                               value="@linha.NumeroLote"
                                               required />
                                        <small class="text-muted">Conforme embalagem</small>
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label small fw-semibold text-muted">
                                            <i class="bi bi-calendar-x me-1"></i>Data Validade *
                                        </label>
                                        <input type="date"
                                               name="Linhas[@i].DataValidade"
                                               class="form-control form-control-lg input-validade"
                                               value="@(linha.DataValidade?.ToString("yyyy-MM-dd"))"
                                               required />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label small fw-semibold text-muted">
                                            <i class="bi bi-geo-alt me-1"></i>Localização *
                                        </label>
                                        <select name="Linhas[@i].LocalizacaoId"
                                                class="form-select form-select-lg"
                                                required>
                                            <option value="">-- Selecione --</option>
                                            @foreach (var loc in localizacoes.OrderBy(l => l.Label))
                                                {
                                                    var selected = linha.LocalizacaoId == loc.Id ? "selected" : "";
                                                    <option value="@loc.Id" selected>
                                                        @loc.Label
                                                    </option>
                                                }
                                        </select>
                                    </div>

                                    @* ALERTA VALIDADE *@
                                    <div class="col-12">
                                        <div class="alert mb-0 alert-validacao-validade d-none py-2">
                                            <i class="bi bi-exclamation-triangle me-1"></i>
                                            <span class="mensagem-validade"></span>
                                        </div>
                                    </div>

                                    @* OBSERVAÇÕES *@
                                    <div class="col-12">
                                        <label class="form-label small fw-semibold text-muted">
                                            <i class="bi bi-chat-left-text me-1"></i>Observações / Diferenças / Danos
                                        </label>
                                        <textarea name="Linhas[@i].Observacoes"
                                                  class="form-control"
                                                  rows="2"
                                                  placeholder="Embalagem danificada, quantidade divergente, produto com defeito..."></textarea>
                                    </div>

                                    @* CONFIRMAÇÃO *@
                                    <div class="col-12">
                                        <div class="card border-0 bg-white shadow-sm">
                                            <div class="card-body py-2 px-3">
                                                <div class="form-check mb-0">
                                                    <input class="form-check-input checkbox-conferido"
                                                           type="checkbox"
                                                           id="check@(i)"
                                                           data-index="@i"
                                                           required>
                                                    <label class="form-check-label small" for="check@(i)">
                                                        <strong>Confirmo que conferi fisicamente este artigo e todos os dados estão corretos</strong>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── OBSERVAÇÕES GERAIS ── *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 py-3">
            <h6 class="mb-0 fw-bold">
                <i class="bi bi-clipboard-check me-2"></i>Observações Gerais da Receção
            </h6>
        </div>
        <div class="card-body pt-0">
            <label asp-for="Observacoes" class="form-label small fw-semibold text-muted">
                Notas sobre a receção (opcional)
            </label>
            <textarea asp-for="Observacoes"
                      class="form-control"
                      rows="3"
                      placeholder="Ex: Entrega realizada no período da manhã, transportadora XYZ, condutor João Silva..."></textarea>
        </div>
    </div>

    @* ── RESUMO FINAL ── *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 py-3">
            <h6 class="mb-0 fw-bold">
                <i class="bi bi-clipboard-data me-2"></i>Resumo da Receção
            </h6>
        </div>
        <div class="card-body">

            @* MÉTRICAS *@
            <div class="row g-3 text-center mb-4">
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light h-100 py-2">
                        <span class="text-muted small">Total Artigos</span>
                        <strong class="fs-3">@encomenda.Linhas.Count</strong>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light h-100 py-2">
                        <span class="text-muted small">A Recepcionar</span>
                        <strong class="fs-3 text-primary" id="resumoUnidadesRecepcionar">0</strong>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light h-100 py-2">
                        <span class="text-muted small">Após Receção</span>
                        <strong class="fs-3" id="resumoTotalAposRecepcao">@encomenda.TotalArtigosRecebidos</strong>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light h-100 py-2">
                        <span class="text-muted small">Ainda Pendente</span>
                        <strong class="fs-3 text-warning" id="resumoPendente">@(encomenda.TotalArtigosAprovados - encomenda.TotalArtigosRecebidos)</strong>
                    </div>
                </div>
            </div>

            <div id="alertDiferenca" class="alert d-none mb-4">
                <i class="bi bi-exclamation-triangle me-1"></i>
                <span id="mensagemDiferenca"></span>
            </div>

            <hr class="my-3">

            @* CONFIRMAÇÕES FINAIS *@
            <div class="d-flex flex-column gap-2">
                <div class="card border-0 bg-light">
                    <div class="card-body py-2 px-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="checkFinal1" required>
                            <label class="form-check-label small" for="checkFinal1">
                                Conferi fisicamente todos os artigos registados acima
                            </label>
                        </div>
                    </div>
                </div>
                <div class="card border-0 bg-light">
                    <div class="card-body py-2 px-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="checkFinal2" required>
                            <label class="form-check-label small" for="checkFinal2">
                                Validei todos os lotes e datas de validade
                            </label>
                        </div>
                    </div>
                </div>
                <div class="card border-0 bg-light">
                    <div class="card-body py-2 px-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="checkFinal3" required>
                            <label class="form-check-label small" for="checkFinal3">
                                Defini as localizações de armazenamento corretamente
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── BOTÕES FINAIS ── *@
    <div class="d-flex justify-content-between mb-5">
        <a asp-action="Detalhes" asp-route-id="@encomenda.Id" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle me-1"></i>Cancelar
        </a>
        <button type="submit" class="btn btn-success btn-lg" id="btnRegistarBottom" disabled>
            <i class="bi bi-check-circle me-1"></i>Registar Receção e Atualizar Stocks
        </button>
    </div>
</form>

@* ══════════════════════════════════════════════════════════════════════ *@
@* STYLES — espelham o padrão dos Detalhes *@
@* ══════════════════════════════════════════════════════════════════════ *@

<style>
    .icon-circle {
        width: 36px;
        height: 36px;
        min-width: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon-circle-sm {
        width: 28px;
        height: 28px;
        min-width: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* Accordion sem fundo azul ao expandir */
    .accordion-button:not(.collapsed) {
        background-color: #fff;
        color: #000;
        box-shadow: none;
    }

    .accordion-button:focus {
        box-shadow: none;
    }

    .artigo-item {
        transition: background-color 0.2s;
    }

    .artigo-item.conferido .accordion-button {
        background-color: #f0fff4 !important;
    }

    /* Quantidade — destaque visual suave */
    .input-qtd-recebida {
        font-size: 1.4rem;
        font-weight: 700;
        color: #0d6efd;
        border: 2px solid #dee2e6;
    }

    .input-qtd-recebida:focus {
        border-color: #0d6efd;
    }

    .input-lote {
        font-family: 'SFMono-Regular', Consolas, monospace;
        font-weight: 600;
        letter-spacing: 0.03em;
    }

    /* Checkboxes verdes ao marcar */
    .form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }

    .checkbox-conferido:checked + label {
        color: #198754;
        font-weight: 600;
    }
</style>

@* ══════════════════════════════════════════════════════════════════════ *@
@* SCRIPTS — lógica original preservada *@
@* ══════════════════════════════════════════════════════════════════════ *@

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            const totalLinhas = @encomenda.Linhas.Count;
            const totalJaRecebido = @encomenda.TotalArtigosRecebidos;

            // ── VALIDAR QUANTIDADE ──────────────────────────────────────
            $('.input-qtd-recebida').on('input', function () {
                const max = parseInt($(this).data('max'));
                const valor = parseInt($(this).val()) || 0;
                const artigo = $(this).data('artigo');

                if (valor > max) {
                    alert(`Quantidade recebida de "${artigo}" não pode ser maior que ${max}!`);
                    $(this).val(max);
                }
                if (valor < 0) $(this).val(0);

                atualizarResumo();
            });

            // ── VALIDAR VALIDADE ────────────────────────────────────────
            $('.input-validade').on('change', function () {
                const $item = $(this).closest('.artigo-item');
                const $alert = $item.find('.alert-validacao-validade');
                const $mensagem = $item.find('.mensagem-validade');

                const dataValidade = new Date($(this).val());
                const hoje = new Date();
                const dias = Math.floor((dataValidade - hoje) / (1000 * 60 * 60 * 24));

                $alert.addClass('d-none').removeClass('alert-warning alert-danger');

                if (dias < 0) {
                    $mensagem.text('Produto JÁ VENCIDO! Não deve ser aceite.');
                    $alert.removeClass('d-none').addClass('alert-danger');
                } else if (dias < 30) {
                    $mensagem.text(`Produto vence em ${dias} dias. Prazo muito curto!`);
                    $alert.removeClass('d-none').addClass('alert-danger');
                } else if (dias < 90) {
                    $mensagem.text(`Produto vence em ${dias} dias. Atenção ao prazo!`);
                    $alert.removeClass('d-none').addClass('alert-warning');
                }
            });

            // ── CONTADOR + ESTADO VISUAL DO ARTIGO ─────────────────────
            $('.checkbox-conferido').on('change', function () {
                const total = $('.checkbox-conferido:checked').length;
                $('#artigosConferidos').text(total);

                const $item = $(this).closest('.artigo-item');
                const $icon = $item.find('.artigo-icon i');

                if ($(this).is(':checked')) {
                    $item.addClass('conferido');
                    $icon.removeClass('bi-circle bi-hourglass-split text-secondary text-warning')
                         .addClass('bi-check-circle-fill text-success');
                    $item.find('.artigo-icon')
                         .removeClass('bg-secondary bg-warning')
                         .addClass('bg-success');
                } else {
                    $item.removeClass('conferido');
                    $icon.removeClass('bi-check-circle-fill text-success')
                         .addClass('bi-circle text-secondary');
                    $item.find('.artigo-icon')
                         .removeClass('bg-success')
                         .addClass('bg-secondary');
                }

                validarFormulario();
            });

            // ── ATUALIZAR RESUMO ────────────────────────────────────────
            function atualizarResumo() {
                let totalRecepcionar = 0;
                $('.input-qtd-recebida').each(function () {
                    totalRecepcionar += parseInt($(this).val()) || 0;
                });

                const totalApos = totalJaRecebido + totalRecepcionar;
                const totalAprovado = @encomenda.TotalArtigosAprovados;
                const pendente = totalAprovado - totalApos;

                $('#resumoUnidadesRecepcionar').text(totalRecepcionar);
                $('#resumoTotalAposRecepcao').text(totalApos);
                $('#resumoPendente').text(Math.max(pendente, 0));

                const $alert = $('#alertDiferenca');
                $alert.removeClass('alert-warning alert-success alert-danger d-none');

                if (pendente > 0) {
                    $('#mensagemDiferenca').text(`Após esta receção ainda faltarão ${pendente} unidades. A encomenda ficará com estado PARCIAL.`);
                    $alert.addClass('alert-warning');
                } else if (pendente === 0) {
                    $('#mensagemDiferenca').text('Esta receção completará a encomenda! Estado mudará para CONCLUÍDA.');
                    $alert.addClass('alert-success');
                } else {
                    $('#mensagemDiferenca').text(`Atenção! Está a recepcionar ${Math.abs(pendente)} unidades A MAIS do que o aprovado!`);
                    $alert.addClass('alert-danger');
                }

                validarFormulario();
            }

            // ── VALIDAR FORMULÁRIO ──────────────────────────────────────
            function validarFormulario() {
                const todosConferidos = $('.checkbox-conferido:checked').length === totalLinhas;
                const check1 = $('#checkFinal1').is(':checked');
                const check2 = $('#checkFinal2').is(':checked');
                const check3 = $('#checkFinal3').is(':checked');

                let temRecepcao = false;
                $('.input-qtd-recebida').each(function () {
                    if (parseInt($(this).val()) > 0) temRecepcao = true;
                });

                const valido = todosConferidos && check1 && check2 && check3 && temRecepcao;
                $('#btnRegistar, #btnRegistarBottom').prop('disabled', !valido);
            }

            $('#checkFinal1, #checkFinal2, #checkFinal3').on('change', validarFormulario);

            // ── CONFIRMAÇÃO ANTES DE SUBMETER ───────────────────────────
            $('#formRecepcao').submit(function (e) {
                let totalRecepcionar = 0;
                $('.input-qtd-recebida').each(function () {
                    totalRecepcionar += parseInt($(this).val()) || 0;
                });

                const totalApos = totalJaRecebido + totalRecepcionar;
                const totalAprovado = @encomenda.TotalArtigosAprovados;
                const estadoFinal = totalApos >= totalAprovado ? 'CONCLUÍDA' : 'PARCIAL';

                const confirmar = confirm(
                    `Confirmar receção?\n\n` +
                    `Unidades a recepcionar: ${totalRecepcionar}\n` +
                    `Total após receção: ${totalApos} / ${totalAprovado}\n\n` +
                    `Os stocks serão atualizados automaticamente.\n` +
                    `Estado final: ${estadoFinal}\n\n` +
                    `Deseja continuar?`
                );

                if (!confirmar) {
                    e.preventDefault();
                    return false;
                }

                $('#btnRegistar, #btnRegistarBottom')
                    .prop('disabled', true)
                    .html('<span class="spinner-border spinner-border-sm me-2"></span>A processar...');

                return true;
            });

            // Inicializar resumo
            atualizarResumo();
        });
    </script>
}
