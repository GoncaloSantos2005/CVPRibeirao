@using SistemaPDI.Contracts.DTOs
@model List<ArtigoDto>
@{
    var perfil = ViewBag.Perfil as string;
    Layout = perfil == "SOCORRISTA"
        ? "~/Views/Shared/_LayoutSocorrista.cshtml"
        : "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Gestão de Artigos";
    var podeGerir = perfil == "ADMINISTRADOR" || perfil == "GESTOR";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 text-dark">Gestão de Artigos</h4>
        <p class="text-muted mb-0" style="font-size: 13px;">Gira o catálogo e os limites de stock.</p>
    </div>
    @if (podeGerir)
    {
        <a asp-action="Criar" class="btn btn-cvp">
            <i class="bi bi-plus-lg me-1"></i> Novo Artigo
        </a>
    }
</div>

<div class="mb-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary @(ViewData["Filtro"] == null ? "active" : "")">Todos</a>
    <a asp-action="StockBaixo" class="btn btn-sm btn-outline-warning @(ViewData["Filtro"]?.ToString() == "stock-baixo" ? "active" : "")">Stock Baixo</a>
    <a asp-action="StockCritico" class="btn btn-sm btn-outline-danger @(ViewData["Filtro"]?.ToString() == "stock-critico" ? "active" : "")">Crítico</a>
    @if (podeGerir)
    {
        <a asp-action="Desativados" class="btn btn-sm btn-outline-secondary @(ViewData["Filtro"]?.ToString() == "desativados" ? "active" : "")">Desativados</a>
    }
</div>

<div class="card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" id="tabelaArtigos">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width: 60px;">Imagem</th>
                    <th>SKU</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Stock Atual</th>
                    <th>Mín / Crítico</th>
                    <th class="text-end pe-3">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center py-5 text-muted">Nenhum artigo encontrado no catálogo.</td></tr>
                }
                else
                {
                    foreach (var a in Model)
                    {
                        <tr class="@(a.Ativo ? "" : "table-secondary")">
                            <td class="ps-3">
                                @if (!string.IsNullOrEmpty(a.UrlImagem))
                                {
                                    <img src="@a.UrlImagem" alt="@a.Nome" 
                                         class="rounded" 
                                         style="width: 45px; height: 45px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                                         style="width: 45px; height: 45px;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold text-muted" style="font-size: 12px;">@a.SKU</td>
                            <td class="fw-semibold text-dark">@a.Nome</td>
                            <td><span class="badge bg-light text-dark border">@a.NomeCategoria</span></td>
                            <td>
                                <strong class="fs-6">@a.StockVirtual</strong>
                                @if (a.EstaCritico)
                                {
                                    <span class="badge bg-danger ms-1" style="font-size:10px;">CRÍTICO</span>
                                }
                                else if (a.NecessitaReposicao)
                                {
                                    <span class="badge bg-warning text-dark ms-1" style="font-size:10px;">ATENÇÃO</span>
                                }
                                else
                                {
                                    <span class="badge bg-success ms-1" style="font-size:10px;">OK</span>
                                }
                            </td>
                            <td class="text-muted small">@a.StockMinimo / @a.StockCritico</td>
                            <td class="text-end pe-3">
                                @if (podeGerir)
                                {
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="Editar" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary py-1 px-2 border-0" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <form asp-action="AlternarEstado" asp-route-id="@a.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary py-1 px-2 border-0" title="Ativar/Desativar">
                                            <i class="bi bi-power"></i>
                                        </button>
                                    </form>

                                    @if (perfil == "ADMINISTRADOR")
                                    {
                                        <form asp-action="Remover" asp-route-id="@a.Id" method="post" style="display:inline;"
                                              onsubmit="return confirm('ATENÇÃO: Deseja apagar permanentemente este artigo?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2 border-0">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>