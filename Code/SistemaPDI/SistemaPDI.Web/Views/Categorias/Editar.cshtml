@using SistemaPDI.Contracts.DTOs
@model AtualizarCategoriaDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Editar Categoria";
    var categoriaAtual = ViewBag.CategoriaAtual as CategoriaDto;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none small text-muted">
        <i class="bi bi-arrow-left"></i> Voltar às Categorias
    </a>
    <h4 class="fw-bold text-dark mt-2">Editar Categoria: <span class="text-cvp">@categoriaAtual?.Nome</span></h4>
    <p class="text-muted" style="font-size: 13px;">Atualize as informações da categoria.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4">
            <form asp-action="Editar" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Nome da Categoria <span class="text-danger">*</span></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Descrição</label>
                    <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                    <button type="submit" class="btn btn-cvp px-4">
                        <i class="bi bi-save me-1"></i> Guardar Alterações
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <h6 class="fw-bold text-uppercase small mb-3 text-muted">Informações</h6>
                <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                    <span class="small fw-semibold">Total de Artigos:</span>
                    <span class="badge bg-secondary fs-6">@categoriaAtual?.TotalArtigos</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small fw-semibold">Estado:</span>
                    @if (categoriaAtual?.Ativo == true)
                    {
                        <span class="badge bg-success">Ativa</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inativa</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}