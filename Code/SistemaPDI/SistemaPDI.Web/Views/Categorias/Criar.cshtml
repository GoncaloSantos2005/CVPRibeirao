@using SistemaPDI.Contracts.DTOs
@model CriarCategoriaDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Nova Categoria";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none small text-muted">
        <i class="bi bi-arrow-left"></i> Voltar às Categorias
    </a>
    <h4 class="fw-bold text-dark mt-2">Criar Nova Categoria</h4>
    <p class="text-muted" style="font-size: 13px;">Defina uma nova categoria para organizar os artigos.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4">
            <form asp-action="Criar" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Nome da Categoria <span class="text-danger">*</span></label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Equipamento de Proteção Individual" />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Descrição</label>
                    <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Descrição opcional..."></textarea>
                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                    <button type="submit" class="btn btn-cvp px-4">Guardar Categoria</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
